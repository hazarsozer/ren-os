{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "RenOS hook registrations. /ren:doctor greps the 'command' field for 'ren-wake-up.py' (primary) and the 'description' field for 'ren-wake-up:' (sentinel) — both should be preserved when editing.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/hooks/wake-up/ren-wake-up.py\"",
            "timeout": 10,
            "description": "ren-wake-up: SessionStart context injection per ADR-008 (fresh sessions)",
            "id": "ren-wake-up-startup"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/hooks/wake-up/ren-wake-up.py\"",
            "timeout": 10,
            "description": "ren-wake-up: re-inject context after compaction per hooks-guide compact-matcher pattern",
            "id": "ren-wake-up-compact"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/hooks/guards/pre_push_scan.py\"",
            "timeout": 20,
            "description": "ren-pre-push-scan: force-push guard + outgoing push content/secrets scan (spec §3.6 A-8 items 1+6)",
            "id": "ren-pre-push-scan"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/hooks/guards/write_gate.py\"",
            "timeout": 10,
            "description": "ren-write-gate: wiki mass-delete guard + backup-remote-change confirmation (spec §3.6 A-8 items 2+6)",
            "id": "ren-write-gate-bash"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/hooks/guards/write_gate.py\"",
            "timeout": 10,
            "description": "ren-write-gate: durable wiki writes go through the queue, not direct edits (spec §3.6 A-8 item 5)",
            "id": "ren-write-gate-direct"
          }
        ]
      }
    ]
  }
}
