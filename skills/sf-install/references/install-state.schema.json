{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://startup-framework.dev/schemas/install-state.v1.json",
  "title": "sf-install checkpoint state",
  "description": "Machine-local install state for /sf:install. Persisted at $XDG_STATE_HOME/sf/install-state.json. Authoritative source for resume protocol decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "framework_version",
    "started_at",
    "last_updated_at",
    "completed_stages",
    "stage_artifacts",
    "abort_log"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Bump on backwards-incompatible state-file changes. Older framework versions refuse to read newer schemas."
    },
    "framework_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$",
      "description": "Semver of the framework that started this install."
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_stages": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 7
      },
      "uniqueItems": true,
      "description": "Stages that have successfully completed at least once. Re-running /sf:install skips them unless they have always_recheck=true."
    },
    "stage_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "description": "Per-stage outputs the resume protocol uses to decide what to skip.",
      "properties": {
        "1": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "env_ok": { "type": "boolean" },
            "checks": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "claude_auth": { "type": "boolean" },
                "gh_auth": { "type": "boolean" },
                "node_version": { "type": "string" },
                "node_ok": { "type": "boolean" },
                "git_ok": { "type": "boolean" },
                "anthropic_api_key": { "type": "boolean" },
                "upstash_context7_api_key": { "type": "boolean" }
              }
            },
            "last_check_at": { "type": "string", "format": "date-time" }
          }
        },
        "2": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plugins_installed"],
          "properties": {
            "plugins_installed": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "version"],
                "properties": {
                  "name": { "type": "string" },
                  "version": { "type": "string" }
                }
              },
              "description": "Ordered list of plugins successfully installed. Re-run resumes after the last entry."
            }
          }
        },
        "3": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "frontend_design_installed": { "type": "boolean" },
            "frontend_design_dismissed": { "type": "boolean" },
            "ralph_loop_documented_only": { "type": "boolean" }
          }
        },
        "4": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "identity_path": { "type": "string" },
            "handle_written": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*$"
            }
          }
        },
        "5": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "wiki_root": { "type": "string" },
            "skeleton_schema_version": { "type": "integer" },
            "additive_changes_applied": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Paths written this run. Empty on a no-op re-run."
            },
            "additive_changes_declined": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Paths the friend explicitly declined to add."
            }
          }
        },
        "6": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "doctor_passed": { "type": "boolean" },
            "otel_enabled": { "type": "boolean" },
            "licenses_md_written": { "type": "boolean" },
            "last_check_at": { "type": "string", "format": "date-time" }
          }
        },
        "7": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "walkthrough_acknowledged": { "type": "boolean" },
            "acknowledged_at": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "abort_log": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "error_summary", "ts"],
        "properties": {
          "stage": { "type": "integer", "minimum": 1, "maximum": 7 },
          "error_summary": { "type": "string" },
          "error_detail": { "type": "string" },
          "ts": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Bounded ring buffer of recent aborts for postmortem. Older entries are dropped on overflow."
    }
  }
}
